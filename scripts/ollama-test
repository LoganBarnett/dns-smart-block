#!/usr/bin/env bash
# Run the model evaluation integration tests against a temporary Ollama
# instance.  Ollama is started on a non-default port so it does not collide
# with any production instance already running on the host.
#
# Usage:
#   scripts/ollama-test                  # uses default model (llama3.2:1b)
#   MODEL=qwen2.5:0.5b scripts/ollama-test
#   MODEL=llama3.2:3b scripts/ollama-test
#
# Any extra arguments are forwarded to cargo test:
#   scripts/ollama-test --no-fail-fast
#
# Environment variables:
#   MODEL             Ollama model to pull and test with (default: llama3.2:1b)
#   OLLAMA_TEST_PORT  Port for the temporary Ollama instance (default: 11435)
set -euo pipefail

MODEL="${MODEL:-llama3.2:1b}"
OLLAMA_TEST_PORT="${OLLAMA_TEST_PORT:-11435}"
OLLAMA_TEST_HOST="127.0.0.1:${OLLAMA_TEST_PORT}"
OLLAMA_TEST_URL="http://${OLLAMA_TEST_HOST}"
OLLAMA_LOG="$(mktemp --suffix='-ollama-test.log')"
OLLAMA_PID=""

cleanup() {
  if [[ -n "${OLLAMA_PID}" ]]; then
    echo "Stopping Ollama (PID ${OLLAMA_PID})…"
    kill "${OLLAMA_PID}" 2>/dev/null || true
    wait "${OLLAMA_PID}" 2>/dev/null || true
    echo "Ollama stopped."
  fi
  rm -f "${OLLAMA_LOG}"
}
trap cleanup EXIT

# ---------------------------------------------------------------------------
# Start Ollama
# ---------------------------------------------------------------------------
echo "Starting Ollama on ${OLLAMA_TEST_HOST}…"
OLLAMA_HOST="${OLLAMA_TEST_HOST}" ollama serve >"${OLLAMA_LOG}" 2>&1 &
OLLAMA_PID=$!

echo "Waiting for Ollama to be ready…"
for i in $(seq 1 30); do
  if curl --silent --fail "${OLLAMA_TEST_URL}/api/tags" >/dev/null 2>&1; then
    echo "Ollama is ready."
    break
  fi
  if [[ "${i}" -eq 30 ]]; then
    echo "ERROR: Ollama did not become ready after 30 seconds." >&2
    echo "--- Ollama log ---" >&2
    cat "${OLLAMA_LOG}" >&2
    exit 1
  fi
  sleep 1
done

# ---------------------------------------------------------------------------
# Pull model
# ---------------------------------------------------------------------------
echo "Pulling model ${MODEL} (skipped if already cached)…"
OLLAMA_HOST="${OLLAMA_TEST_HOST}" ollama pull "${MODEL}"

# ---------------------------------------------------------------------------
# Run tests
# ---------------------------------------------------------------------------
echo ""
echo "Running model evaluation tests with ${MODEL}…"
echo ""

OLLAMA_URL="${OLLAMA_TEST_URL}" \
MODEL="${MODEL}" \
  cargo test \
    --package dns-smart-block-classifier \
    --test model_evaluation_test \
    test_custom_model \
    -- --ignored --nocapture "$@"
